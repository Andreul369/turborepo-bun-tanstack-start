# Port
PORT=3003


# Environment
NODE_ENV=development


# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=<previously SUPABASE_ANON_KEY>
SUPABASE_SECRET_KEY=<previously SUPABASE_SERVICE_KEY>


# Config
# ALLOWED_API_ORIGINS is the list of origins allowed by CORS.
# The browser sends an Origin header (e.g. http://localhost:3001)
# when a page makes a request to the API. The API checks that origin against this list.
# Only the dashboard calls the API.
ALLOWED_API_ORIGINS="http://localhost:3001"
LOG_LEVEL=debug